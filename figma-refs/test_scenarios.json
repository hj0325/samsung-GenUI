{
  "_doc": "Fixed scenario suite for the self-improving system. Each scenario carries expected qualities the test runner uses to score the pipeline output. New scenarios should follow the same shape; remove ones that prove unreliable or duplicate signal.\n\nHELD-OUT VALIDATION: scenarios with `holdout: true` are NEVER shown to the pattern-extraction LLM. They're only used to score after a rule is applied. A rule must improve BOTH training and validation scores to be accepted. This catches overfit — rules that fit the 15 training scenarios but break the 5 validation scenarios are auto-rejected.",
  "_version": 1,
  "_scoring": {
    "weights": {
      "violation_high":    -10,
      "violation_medium":  -3,
      "violation_low":     -1,
      "richness_per_card": 4,
      "richness_cap":      32,
      "expected_component_present": 6,
      "expected_component_missing": -4,
      "expected_surface_match": 8,
      "expected_surface_mismatch": -8,
      "no_silent_drops":   3
    },
    "thresholds": {
      "improvement_required_pct": 5,
      "regression_alert_pct":    -3
    }
  },
