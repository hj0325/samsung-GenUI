{
  "system_name": "genui_pipeline_v1",
  "goal": "사용자 시나리오를 바로 UI로 즉흥 생성하지 않고, state 기반으로 필요한 컴포넌트를 선택하고, registry와 ruleset을 참조해 조합 가능한 UI를 생성한 뒤 validator를 통과시켜 최종 결과를 설명 가능한 형태로 반환한다.",
  "pipeline": {
    "input": {
      "scenario_text": "string",
      "user_context": {
        "device_type": "mobile | tablet | foldable | tv | auto | desktop",
        "current_surface": "lock | home | app",
        "window_mode": "single | split | floating",
        "attention_mode": "focused | glanceable | distracted",
        "mobility_mode": "stationary | walking | driving | transit",
        "urgency": "low | medium | high",
        "interaction_preference": "touch | voice | mixed | minimal-touch"
      }
    },
    "step_1_scenario_interpretation": {
      "description": "사용자 시나리오를 intent, context, tasks, constraints로 구조화한다.",
      "output_schema": {
        "intent": { "primary_goal": "string", "secondary_goal": "string | null" },
        "context": {
          "environment": "string",
          "attention_mode": "focused | glanceable | distracted",
          "urgency": "low | medium | high",
          "mobility_mode": "stationary | walking | driving | transit",
          "interaction_mode": "touch | voice | mixed | minimal-touch"
        },
        "tasks": [{ "task_id": "string", "type": "string", "priority": "1 | 2 | 3", "content_need": "string" }],
        "constraints": ["minimal_text","large_touch_targets","single_glance_readability","reduce_visual_density","one_hand_use","low_cognitive_load"]
      }
    },
    "step_2_ui_state_resolution": {
      "description": "시나리오를 화면 이름으로 바로 바꾸지 않고, UI 상태값으로 변환한다.",
      "output_schema": {
        "ui_state": {
          "base_surface": "lock | home | app",
          "home_substate": "none | launcher | app-drawer | widget-edit",
          "overlay_type": "none | quick-settings | notification-shade | system-dialog",
          "overlay_coverage": "none | partial | full",
          "window_mode": "single | split | floating",
          "attention_mode": "focused | glanceable | distracted",
          "density_mode": "expanded | normal | compressed",
          "interaction_mode": "touch | voice | mixed | minimal-touch",
          "background_policy": "wallpaper | solid-dark | scrim-over-wallpaper | scrim-over-app | dialog-surface"
        }
      },
      "resolver_logic": {
        "rules": [
          "lock와 home 계열은 wallpaper 허용",
          "app 기본 상태는 solid-dark",
          "quick-settings와 notification-shade는 overlay이며 base_surface를 대체하지 않음",
          "system-dialog는 dialog-surface 사용",
          "driving 또는 glanceable이면 density_mode는 compressed 우선",
          "minimal-touch이면 interaction_mode를 minimal-touch로 고정"
        ]
      }
    },
    "step_3_component_planning": {
      "description": "필요한 UI를 자유 생성하지 않고, registry에 존재하는 컴포넌트 타입 목록 중에서만 선택한다.",
      "selection_rules": [
        "component_type은 registry vocabulary 내에서만 선택 가능",
        "새로운 컴포넌트 이름을 invent하지 말 것",
        "attention_mode가 glanceable이면 긴 텍스트형 component 배제",
        "minimal-touch이면 작은 action cluster 배제",
        "priority 3 이하는 공간 부족 시 collapse 대상"
      ]
    },
    "step_4_component_registry": {
      "description": "각 컴포넌트는 markdown 설명이 아니라 JSON spec으로 실행 가능하게 등록되어 있어야 한다.",
      "component_schema": {
        "id": "string",
        "category": "string",
        "allowed_contexts": ["string"],
        "states": ["default","compact","glance"],
        "slots": {
          "title": "text | optional",
          "value": "text | optional",
          "icon": "icon | optional",
          "actions": "action-group | optional"
        },
        "layout_spec": {
          "min_width": "number",
          "min_height": "number",
          "padding": { "top":"number","right":"number","bottom":"number","left":"number" },
          "gap": "number"
        },
        "tokens": {
          "radius": "string",
          "background": "string",
          "text_style_title": "string",
          "text_style_value": "string"
        },
        "behavior": { "interactive": "boolean", "collapse_priority": "1 | 2 | 3" }
      }
    },
    "step_5_layout_composition": {
      "description": "선택된 컴포넌트를 orchestration ruleset과 layout spec에 따라 조합한다.",
      "composition_rules": [
        "rule engine은 spacing, padding, grouping 기준을 강제한다",
        "component variant는 ui_state와 constraints에 따라 선택한다",
        "priority 낮은 항목은 공간 부족 시 축소 또는 제거 가능",
        "layout 결정은 알고리즘이 하고 LLM은 설명만 한다"
      ]
    },
    "step_6_validation": {
      "description": "생성된 layout_plan과 component spec을 validator가 검사한다.",
      "validators": [
        "spacing_scale_rule",
        "touch_target_min",
        "border_min",
        "context_component_match",
        "layout_overflow_check"
      ]
    },
    "step_7_explanation_layer": {
      "description": "LLM은 최종 실행 로직이 아니라 설명과 수정 제안만 담당한다.",
      "output_schema": {
        "why_this_ui": "string",
        "what_was_prioritized": ["string"],
        "what_was_removed_or_collapsed": ["string"],
        "what_should_be_fixed": ["string"]
      }
    }
  },
  "execution_contract": {
    "hard_rules": [
      "LLM은 새로운 component_type을 invent하지 않는다",
      "모든 실행 가능한 spec은 JSON registry에서만 온다",
      "markdown은 설명용이며 실행 기준이 아니다",
      "validator를 통과하지 못한 layout은 final UI로 승격되지 않는다",
      "scenario에서 바로 UI markup을 생성하지 않는다"
    ],
    "fallback_rules": [
      "required_components가 과도하면 priority 3부터 collapse",
      "attention_mode가 glanceable이면 text-heavy component 제거",
      "context mismatch가 발생하면 component planner 재실행",
      "layout overflow가 발생하면 compact variant 재선택"
    ]
  },
  "recommended_files": {
    "scenario_prompt_md": "설명용 프롬프트 문서",
    "component_registry_json": "실행용 컴포넌트 사전",
    "ruleset_json": "spacing, grouping, orchestration 룰",
    "state_resolver_json": "상태 판정 규칙",
    "validator_js": "검사 엔진",
    "explanation_prompt_md": "최종 설명용 프롬프트"
  },
  "minimal_runtime_order": [
    "scenario_text 입력",
    "scenario_interpreter 실행",
    "ui_state_resolver 실행",
    "component_planner 실행",
    "component_registry lookup",
    "layout_composer 실행",
    "validator 실행",
    "llm explanation 생성"
  ]
}
